                <string notr="true">QPushButton {
    background-color: rgb(255, 255, 255);     /* 기본 배경 */
    color: black;
    border: 1px solid rgb(154, 153, 150);
    padding: 8px;
    border-radius: 5px;
}
/* 마우스 올렸을 때 (hover) */
QPushButton:hover {
    background-color: rgb(203, 227, 255);    /* hover 배경 */
}

/* 클릭 상태 (hover + pressed 겹칠 경우 우선 적용) */
QPushButton:pressed {
    background-color: #DDA853;     /* 클릭 시 배경 */
}</string>
